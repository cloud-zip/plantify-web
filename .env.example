# GitHub Pages/Vite frontend-safe config
# This dashboard calls a Supabase Edge Function deployed with --no-verify-jwt.
# Therefore anon key can stay empty.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: if your repo is deployed at https://USERNAME.github.io/REPO_NAME/
# set VITE_BASE_PATH=/REPO_NAME/
VITE_BASE_PATH=/
